{
  "name": "clippy-claude",
  "version": "2.7.0",
  "description": "Joe — a sassy banana companion that floats on your macOS desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "release": "electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.bananajoe.clippy-claude",
    "productName": "Clippy Claude",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": "Andrea Deotto (3A45BSS4QX)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": true,
      "type": "distribution"
    },
    "dmg": {
      "sign": false
    },
    "publish": {
      "provider": "github",
      "owner": "Banana-joe-games",
      "repo": "joe-companion"
    },
    "files": [
      "main.js",
      "preload.js",
      "shell.html",
      "onboarding.html",
      "firebase-config.js",
      "cal-helper",
      "modules/**",
      "scripts/**"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0"
  }
}
